<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TableColumn?>
<?import de.vw.paso.client.control.table.CustomTableView?>
<Tab
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"

        fx:controller="de.vw.paso.client.stueckliste.efs.views.properties.PartPropertiesTabController"
        fx:id="partPropertiesTab"
        text="%tab.partproperties.title"
>

    <CustomTableView fx:id="partPropertiesTable">
        <columns>
            <TableColumn fx:id="colPropertyName" text="%column.property.name"/>
            <TableColumn fx:id="colProperty" text="%column.property.value"/>
        </columns>

    </CustomTableView>

</Tab>
