<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<fx:root type="GridPane"
         xmlns:fx="http://javafx.com/fxml/1"
         xmlns="http://javafx.com/javafx/8">

    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="10.0" prefWidth="100.0"/>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="30.0" minWidth="18.0" prefWidth="30.0"/>
    </columnConstraints>

    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
    </rowConstraints>

    <children>
        <TextField fx:id="textField" styleClass="text-field-efs-header" editable="false" maxHeight="20.0"
                   maxWidth="1.7976931348623157E308" minHeight="20.0" prefHeight="20.0"/>
        <Button fx:id="buttonShowAggregat" maxHeight="18.0" maxWidth="30.0" minHeight="18.0" minWidth="30.0"
                prefHeight="18.0" prefWidth="30.0" GridPane.columnIndex="1"/>
    </children>
</fx:root>
