<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import de.vw.paso.client.control.treetable.CustomTreeTableView?>
<?import de.vw.paso.client.stueckliste.efs.views.historie.columns.EfsTreeTableColumn?>
<Tab xmlns="http://javafx.com/javafx"
     xmlns:fx="http://javafx.com/fxml"

     fx:controller="de.vw.paso.client.stueckliste.compare.ConfigCompareTabController"
     fx:id="tabConfig"
     text="%tab.configuration.title">

    <SplitPane fx:id="configCompareSplitPane" orientation="VERTICAL">
        <items>
            <CustomTreeTableView fx:id="configTreeView" tableMenuButtonVisible="true">
                <columns>
                    <EfsTreeTableColumn fx:id="prNumberFamily" text="%tablecolumn.family"/>
                    <EfsTreeTableColumn fx:id="prNumber" text="%tablecolumn.prnumber"/>
                    <EfsTreeTableColumn fx:id="description1" text="%tablecolumn.description"/>
                    <EfsTreeTableColumn fx:id="description2" text="%tablecolumn.description2"/>
                    <EfsTreeTableColumn fx:id="prNumberBeginDate" text="%tablecolumn.beginDate"/>
                    <EfsTreeTableColumn fx:id="prNumberBeginDateKey" text="%tablecolumn.beginDateKey"/>
                    <EfsTreeTableColumn fx:id="prNumberEndDate" text="%tablecolumn.endDate"/>
                    <EfsTreeTableColumn fx:id="prNumberEndDateKey" text="%tablecolumn.endDateKey"/>
                </columns>
            </CustomTreeTableView>
        </items>
    </SplitPane>
</Tab>
