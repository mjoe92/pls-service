<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<fx:root type="GridPane"
         xmlns:fx="http://javafx.com/fxml/1"
         xmlns="http://javafx.com/javafx/8">

    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="16.0" minWidth="16.0" prefWidth="16.0"/>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="10.0" prefWidth="100.0"/>
    </columnConstraints>

    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="32.0" vgrow="SOMETIMES"/>
    </rowConstraints>

    <children>
        <ImageView fx:id="imageView" GridPane.columnIndex="0">
            <GridPane.margin>
                <Insets right="1.0"/>
                <Insets left="3.0"/>
            </GridPane.margin>
        </ImageView>
        <TextField fx:id="textField" styleClass="text-field-efs-header" editable="false" maxHeight="21.0"
                   maxWidth="1.7976931348623157E308" minHeight="21.0" prefHeight="21.0" GridPane.columnIndex="1"/>
    </children>
</fx:root>
