<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import de.vw.paso.client.control.textfield.PasoCustomTextFieldClearable?>
<Tab xmlns:fx="http://javafx.com/fxml"
     fx:id="explorerTab"
     text="%tab.explorer.title"
     fx:controller="de.vw.paso.client.explorer.ExplorerTabController">

    <SplitPane dividerPositions="0.17">
        <items>
            <GridPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" alignment="BASELINE_LEFT">
                <children>
                    <GridPane
                            alignment="BASELINE_LEFT"
                            hgap="5.0"
                            GridPane.columnIndex="0"
                            GridPane.rowIndex="0"
                    >
                        <children>
                            <Label
                                    text="%search"
                                    GridPane.columnIndex="0"
                                    GridPane.rowIndex="0"
                            />
                            <PasoCustomTextFieldClearable
                                    fx:id="explorerSearch"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="0"
                            />
                        </children>
                        <padding>
                            <Insets bottom="5.0" left="5.0" right="0.0" top="5.0"/>
                        </padding>
                    </GridPane>
                    <ScrollPane
                            fitToHeight="true"
                            fitToWidth="true"
                            prefHeight="1280.0"
                            GridPane.columnIndex="0"
                            GridPane.rowIndex="1">
                        <content>
                            <TabPane fx:id="explorerTabPane"/>
                        </content>
                    </ScrollPane>
                </children>
                <columnConstraints>
                    <ColumnConstraints percentWidth="100"/>
                </columnConstraints>
            </GridPane>

            <GridPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
                      alignment="BASELINE_LEFT"
                      hgap="5.0"
            >
                <children>
                    <GridPane
                            fx:id="explorerWorkAreaSearchPane"
                            alignment="BASELINE_LEFT"
                            hgap="5.0"
                            GridPane.columnIndex="0"
                            GridPane.rowIndex="0"
                    >
                        <children>
                            <Label
                                    text="%search"
                                    GridPane.columnIndex="0"
                                    GridPane.rowIndex="0"
                            />
                            <PasoCustomTextFieldClearable
                                    fx:id="explorerWorkAreaSearch"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="0"
                            />
                        </children>
                        <padding>
                            <Insets bottom="5.0" left="5.0" right="0.0" top="5.0"/>
                        </padding>
                    </GridPane>
                    <BorderPane
                            fx:id="explorerWorkArea"
                            GridPane.columnIndex="0"
                            GridPane.rowIndex="1"
                    />
                </children>
                <columnConstraints>
                    <ColumnConstraints percentWidth="100"/>
                </columnConstraints>
            </GridPane>

        </items>
    </SplitPane>

</Tab>
