<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import de.vw.paso.client.control.textfield.PasoCustomTextField?>
<GridPane
        fx:id="gridPanePartNumber"

        xmlns="http://javafx.com/javafx/8"
        xmlns:fx="http://javafx.com/fxml/1"

        fx:controller="de.vw.paso.client.stueckliste.teilenummer.TeileNrTextFieldController">

    <columnConstraints>

        <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="175.0" prefWidth="175.0"/>

        <ColumnConstraints hgrow="SOMETIMES" maxWidth="20.0" minWidth="20.0" prefWidth="20.0"/>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="20.0" minWidth="20.0" prefWidth="20.0"/>

    </columnConstraints>

    <rowConstraints>
        <RowConstraints maxHeight="20.0" minHeight="20.0" prefHeight="20.0" vgrow="SOMETIMES"/>
    </rowConstraints>

    <children>

        <PasoCustomTextField fx:id="textfieldPartNumber" alignment="center" GridPane.columnIndex="0"
                             maxTextLength="14" upperCase="true"
                             minWidth="175.0" prefWidth="175.0">
            <GridPane.margin>
                <Insets right="1.0"/>
            </GridPane.margin>
        </PasoCustomTextField>

        <Button fx:id="buttonKopieren" styleClass="button-teilenr-copy-paste" maxHeight="20.0" maxWidth="20.0"
                minHeight="20.0" minWidth="20.0" mnemonicParsing="false" prefHeight="20.0" prefWidth="20.0"
                text="Button"
                GridPane.columnIndex="2"/>
        <Button fx:id="buttonEinfuegen" styleClass="button-teilenr-copy-paste" maxHeight="20.0" maxWidth="20.0"
                minHeight="20.0" minWidth="20.0" mnemonicParsing="false" prefHeight="20.0" prefWidth="20.0"
                text="Button"
                GridPane.columnIndex="3"/>

    </children>
</GridPane>
